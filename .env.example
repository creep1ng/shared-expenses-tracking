# Compose project
COMPOSE_PROJECT_NAME=shared-expenses-tracking

# Reverse proxy
PROXY_HTTP_PORT=8080

# Published preview images
FRONTEND_IMAGE=ghcr.io/creep1ng/shared-expenses-tracking-frontend:main
BACKEND_IMAGE=ghcr.io/creep1ng/shared-expenses-tracking-backend:main

# Frontend runtime
FRONTEND_NODE_ENV=development
NEXT_PUBLIC_API_BASE_PATH=/api
INTERNAL_API_URL=http://backend:8000

# Backend runtime
APP_ENV=development
DATABASE_URL=postgresql+psycopg://<db-user>:<db-password>@db:5432/shared_expenses
REDIS_URL=redis://redis:6379/0
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=transaction-receipts
S3_USE_SSL=false
S3_FORCE_PATH_STYLE=true
TRANSACTION_RECEIPT_MAX_SIZE_BYTES=10485760
SESSION_COOKIE_DOMAIN=localhost
SESSION_COOKIE_SECURE=false

# Postgres
POSTGRES_DB=shared_expenses
POSTGRES_USER=<db-user>
POSTGRES_PASSWORD=<db-password>
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# MinIO
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
