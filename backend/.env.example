APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=shared_expenses
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_ECHO=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=transaction-receipts
S3_USE_SSL=false
S3_FORCE_PATH_STYLE=true
TRANSACTION_RECEIPT_MAX_SIZE_BYTES=10485760
AUTH_COOKIE_NAME=shared_expenses_session
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_SESSION_TTL_SECONDS=604800
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_RESET_TOKEN_TTL_SECONDS=3600
AUTH_RESET_TOKEN_PEPPER=development-reset-token-pepper
AUTH_PASSWORD_PEPPER=development-password-pepper
AUTH_ENABLE_DEV_RESET_TOKEN_RESPONSE=true
WORKSPACE_INVITATION_TTL_SECONDS=604800
